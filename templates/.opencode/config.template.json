{
  "$schema": "https://opencode.ai/config.json",
  "version": "1.0.0",
  "project": {
    "name": "Your Project Name",
    "description": "Brief description of your project",
    "framework": "react|vue|next|nuxt|angular|svelte|other",
    "language": "typescript|javascript",
    "styling": "tailwind|css-modules|styled-components|scss|other"
  },
  "agent": {
    "feature-lead": {
      "enabled": true,
      "model": "primary",
      "mode": "primary",
      "temperature": 0.3,
      "top_p": 0.9,
      "steps": 50,
      "permission": {
        "task": {
          "*": "allow",
          "security-auditor": "ask"
        }
      }
    },
    "system-analyst": {
      "enabled": true,
      "mode": "subagent",
      "temperature": 0.1,
      "top_p": 0.85,
      "steps": 30,
      "permission": {
        "task": {
          "*": "deny",
          "explorer-agent": "allow",
          "context-gatherer": "allow"
        }
      },
      "tools": {
        "write": true,
        "edit": true,
        "bash": false
      }
    },
    "context-gatherer": {
      "enabled": true,
      "mode": "subagent",
      "temperature": 0.1,
      "top_p": 0.8,
      "steps": 20
    },
    "project-planner": {
      "enabled": true,
      "mode": "subagent",
      "temperature": 0.2,
      "top_p": 0.85,
      "steps": 35
    },
    "explorer-agent": {
      "enabled": true,
      "mode": "subagent",
      "temperature": 0.1,
      "top_p": 0.75,
      "steps": 25
    },
    "archiver": {
      "enabled": true,
      "mode": "subagent",
      "temperature": 0.1,
      "top_p": 0.82,
      "steps": 30
    },
    "developer": {
      "enabled": true,
      "mode": "subagent",
      "temperature": 0.2,
      "top_p": 0.9,
      "steps": 100,
      "permission": {
        "task": {
          "*": "ask",
          "pr-reviewer": "allow",
          "test-engineer": "allow"
        }
      },
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "backend-specialist": {
      "enabled": true,
      "mode": "subagent",
      "temperature": 0.25,
      "top_p": 0.9,
      "steps": 80
    },
    "frontend-specialist": {
      "enabled": true,
      "mode": "subagent",
      "temperature": 0.25,
      "top_p": 0.9,
      "steps": 70
    },
    "devops-engineer": {
      "enabled": true,
      "mode": "subagent",
      "temperature": 0.2,
      "top_p": 0.85,
      "steps": 50
    },
    "test-engineer": {
      "enabled": true,
      "mode": "subagent",
      "temperature": 0.15,
      "top_p": 0.82,
      "steps": 60,
      "permission": {
        "task": {
          "*": "deny"
        }
      },
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "pr-reviewer": {
      "enabled": true,
      "mode": "subagent",
      "temperature": 0.1,
      "top_p": 0.8,
      "steps": 40,
      "permission": {
        "task": {
          "*": "deny"
        }
      },
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "security-auditor": {
      "enabled": true,
      "mode": "subagent",
      "temperature": 0.1,
      "top_p": 0.85,
      "steps": 45
    },
    "debugger": {
      "enabled": true,
      "model": "primary",
      "mode": "subagent",
      "temperature": 0.15,
      "top_p": 0.85,
      "steps": 60,
      "permission": {
        "task": {
          "*": "deny"
        }
      },
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "performance-optimizer": {
      "enabled": true,
      "mode": "subagent",
      "temperature": 0.2,
      "top_p": 0.88,
      "steps": 60,
      "permission": {
        "task": {
          "*": "deny"
        }
      },
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    }
  },
  "plugins": {
    "sessionArtifacts": {
      "enabled": true,
      "candidateStage": "brainstorm",
      "archiveCommand": "archive",
      "handoffTool": "session_artifact_handoff"
    },
    "lintFormat": {
      "enabled": true,
      "runOnEdit": true,
      "extensions": [".ts", ".tsx", ".js", ".jsx", ".vue", ".scss", ".css"],
      "commands": {
        "format": "npm run format",
        "lint": "npm run lint"
      }
    },
    "validateStandards": {
      "enabled": true,
      "strictMode": true,
      "checkOnSave": true
    },
    "validateTypescript": {
      "enabled": true,
      "strictMode": true,
      "checkOnSave": true
    }
  },
  "verification": {
    "commands": {
      "typeCheck": "npx tsc --noEmit",
      "lint": "npm run lint",
      "test": "npm test",
      "build": "npm run build",
      "all": "npm test && npm run lint && npx tsc --noEmit && npm run build"
    },
    "successPatterns": {
      "typeCheck": "Found 0 errors",
      "lint": "no problems",
      "test": "All tests passed",
      "build": "Build successful"
    }
  },
  "quality": {
    "testCoverage": {
      "enabled": true,
      "minimum": 70,
      "target": 80
    },
    "maxFileSize": {
      "enabled": true,
      "maxLines": 500,
      "warningLines": 300
    },
    "complexity": {
      "enabled": true,
      "maxCyclomaticComplexity": 10
    }
  },
  "git": {
    "autoCommit": false,
    "commitMessageTemplate": "{{type}}({{scope}}): {{subject}}",
    "branchNamingTemplate": "{{type}}/{{ticket}}-{{description}}",
    "types": ["feat", "fix", "refactor", "docs", "test", "chore"]
  },
  "paths": {
    "agents": ".opencode/agents",
    "skills": ".opencode/skills",
    "plugins": ".opencode/plugins",
    "artifacts": ".opencode/artifacts",
    "templates": ".opencode/templates",
    "context": "context",
    "output": "output",
    "checkpoints": ".opencode/checkpoints"
  },
  "logging": {
    "level": "info",
    "file": ".opencode/opencode.log",
    "console": true
  }
}
